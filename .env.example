# Copy this file to .env and fill in your real key.
# .env is loaded automatically by config.py (via python-dotenv) if present.
# Never commit your actual .env file -- it's excluded in .gitignore.

GEMINI_API_KEY=your-key-here

# Optional: override where the source PDF is read from (defaults to
# looking for any *.pdf inside the data/ folder)
# PDF_PATH=/path/to/1706_03762v7.pdf
